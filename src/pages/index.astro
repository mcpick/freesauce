---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free Sauce — Find Free Sauce at Aussie Pie Shops 🥧">
  <main>
    <section class="hero">
      <h1>FREE SAUCE<br/><span class="sub">AT EVERY PIE SHOP IN AUSTRALIA</span></h1>
      <p class="tagline">Because charging for sauce on a pie is bloody un-Australian.</p>
      <button id="nearMe" class="btn btn-gold">
        📍 Free Sauce Near Me
      </button>
    </section>

    <section class="map-section">
      <div class="map-header">
        <h2>🗺️ The Sauce Map</h2>
        <div class="stats" id="stats"></div>
      </div>
      <div id="map"></div>
      <div class="legend">
        <span class="legend-item"><span class="dot verified"></span> Verified</span>
        <span class="legend-item"><span class="dot unverified"></span> Community Added</span>
      </div>
    </section>

    <section class="cta">
      <h2>Know a spot that does free sauce?</h2>
      <p>Help your fellow Aussies out. Chuck it on the map.</p>
      <a href="/add" class="btn btn-green">🥫 Add a Pie Shop</a>
    </section>

    <footer>
      <p>Made with 🥧 and 🥫 for Australia</p>
      <p class="small">A side quest by legends who reckon sauce should be free.</p>
    </footer>
  </main>

  <style>
    .hero {
      text-align: center;
      padding: 3rem 1.5rem 2rem;
      background: linear-gradient(135deg, var(--sauce-red) 0%, var(--sauce-dark) 100%);
      color: white;
    }

    .hero h1 {
      font-size: clamp(2rem, 6vw, 3.5rem);
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .hero .sub {
      font-size: clamp(0.9rem, 2.5vw, 1.3rem);
      opacity: 0.9;
      letter-spacing: 0.05em;
    }

    .hero .tagline {
      font-size: 1.1rem;
      opacity: 0.85;
      margin: 1rem 0 1.5rem;
      font-style: italic;
    }

    .map-section {
      padding: 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .map-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .map-header h2 {
      font-size: 1.5rem;
      color: var(--meat);
    }

    .stats {
      font-size: 0.9rem;
      color: var(--sauce-red);
      font-weight: 600;
    }

    #map {
      height: 500px;
      border-radius: 1rem;
      border: 3px solid var(--pie-gold);
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      z-index: 1;
    }

    .legend {
      display: flex;
      gap: 1.5rem;
      margin-top: 0.75rem;
      font-size: 0.85rem;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      display: inline-block;
    }

    .dot.verified { background: var(--aussie-green); }
    .dot.unverified { background: var(--pie-gold); }

    .cta {
      text-align: center;
      padding: 3rem 1.5rem;
      background: var(--pie-gold);
    }

    .cta h2 {
      font-size: 1.6rem;
      color: var(--meat);
      margin-bottom: 0.5rem;
    }

    .cta p {
      margin-bottom: 1.5rem;
      color: var(--meat);
      opacity: 0.85;
    }

    footer {
      text-align: center;
      padding: 2rem 1.5rem;
      font-size: 0.9rem;
      opacity: 0.7;
    }

    footer .small {
      font-size: 0.8rem;
      margin-top: 0.25rem;
    }

    @media (max-width: 600px) {
      #map { height: 350px; }
    }
  </style>

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
    const map = L.map('map').setView([-25.5, 134], 4);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors',
      maxZoom: 18,
    }).addTo(map);

    const sauceIcon = (verified) => L.divIcon({
      className: 'sauce-marker',
      html: `<div style="
        background: ${verified ? '#00843D' : '#f39c12'};
        width: 28px; height: 28px;
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        display: flex; align-items: center; justify-content: center;
        font-size: 14px;
      ">🥫</div>`,
      iconSize: [28, 28],
      iconAnchor: [14, 14],
      popupAnchor: [0, -16],
    });

    async function loadShops() {
      try {
        const res = await fetch('/api/shops');
        const shops = await res.json();

        document.getElementById('stats').textContent =
          `${shops.length} sauce spots and counting`;

        shops.forEach(shop => {
          const sauces = shop.sauce_types
            ? shop.sauce_types.split(',').map(s => s.trim()).join(', ')
            : 'tomato';

          L.marker([shop.lat, shop.lng], { icon: sauceIcon(shop.verified) })
            .addTo(map)
            .bindPopup(`
              <div style="font-family:Inter,sans-serif;min-width:180px;">
                <strong style="font-size:1.05rem;">${shop.name}</strong>
                ${shop.verified ? ' <span style="color:#00843D;">✅</span>' : ''}
                <br/>
                <span style="font-size:0.85rem;color:#666;">${shop.address}</span>
                <br/>
                <span style="font-size:0.85rem;">🥫 ${sauces}</span>
              </div>
            `);
        });
      } catch (e) {
        console.error('Failed to load shops:', e);
      }
    }

    loadShops();

    document.getElementById('nearMe').addEventListener('click', () => {
      const btn = document.getElementById('nearMe');
      btn.textContent = '📍 Finding your sauce...';
      btn.disabled = true;

      if (!navigator.geolocation) {
        alert("Your browser doesn't support geolocation, mate.");
        btn.textContent = '📍 Free Sauce Near Me';
        btn.disabled = false;
        return;
      }

      navigator.geolocation.getCurrentPosition(
        (pos) => {
          map.setView([pos.coords.latitude, pos.coords.longitude], 12);
          L.marker([pos.coords.latitude, pos.coords.longitude], {
            icon: L.divIcon({
              className: 'you-marker',
              html: '<div style="background:#3498db;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3);"></div>',
              iconSize: [16, 16],
              iconAnchor: [8, 8],
            })
          }).addTo(map).bindPopup('📍 You are here').openPopup();
          btn.textContent = '📍 Free Sauce Near Me';
          btn.disabled = false;
        },
        () => {
          alert("Couldn't get your location. Check your permissions, legend.");
          btn.textContent = '📍 Free Sauce Near Me';
          btn.disabled = false;
        }
      );
    });
  </script>
</Layout>
