---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
// @ts-ignore - cloudflare:workers is a CF runtime module
import { env } from 'cloudflare:workers';

// Get shop data from params
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Fetch shop data on the server
let shop = null;
let error = null;

try {
  const db = env.DB;
  shop = await db
    .prepare(`
      SELECT 
        s.id, s.name, s.address, s.lat, s.lng, s.sauce_types, s.verified, s.suburb, s.state, s.slug, s.photo_key, s.created_at,
        COALESCE(up_votes.count, 0) as vote_up_count,
        COALESCE(down_votes.count, 0) as vote_down_count,
        COALESCE(
          MAX(v.confirmed_at), 
          s.created_at
        ) as last_activity
      FROM shops s
      LEFT JOIN (
        SELECT shop_id, COUNT(*) as count 
        FROM votes 
        WHERE vote = 'up' AND status = 'confirmed' 
        GROUP BY shop_id
      ) up_votes ON s.id = up_votes.shop_id
      LEFT JOIN (
        SELECT shop_id, COUNT(*) as count 
        FROM votes 
        WHERE vote = 'down' AND status = 'confirmed' 
        GROUP BY shop_id
      ) down_votes ON s.id = down_votes.shop_id
      LEFT JOIN votes v ON s.id = v.shop_id AND v.status = 'confirmed'
      WHERE s.slug = ?
      GROUP BY s.id
    `)
    .bind(slug)
    .first();

  if (!shop) {
    error = 'Shop not found';
  }
} catch (e) {
  error = 'Failed to load shop';
}

if (error || !shop) {
  return Astro.redirect('/');
}

// Fetch confirmed votes with comments
let confirmations: any[] = [];
try {
  const db = env.DB;
  const result = await db
    .prepare(`SELECT vote, comment, confirmed_at FROM votes WHERE shop_id = ? AND status = 'confirmed' ORDER BY confirmed_at DESC LIMIT 50`)
    .bind(shop.id)
    .all();
  confirmations = result.results || [];
} catch (_) {}

// Check for voting success message
const voted = Astro.url.searchParams.get('voted') === '1';

function timeAgo(dateString: string): string {
  const now = new Date();
  const date = new Date(dateString);
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffDays = Math.floor(diffHours / 24);

  if (diffDays > 365) {
    const years = Math.floor(diffDays / 365);
    return `${years} year${years > 1 ? 's' : ''} ago`;
  } else if (diffDays > 30) {
    const months = Math.floor(diffDays / 30);
    return `${months} month${months > 1 ? 's' : ''} ago`;
  } else if (diffDays > 0) {
    return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
  } else if (diffHours > 0) {
    return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
  } else {
    return 'Just now';
  }
}
---

<Layout title={`${shop.name} — Free Sauce`}>
  <main class="shop-page">
    {voted && (
      <div class="voted-banner">
        🎉 Confirmed! Thanks for keeping the sauce map accurate, legend.
      </div>
    )}

    <div class="shop-header">
      <div class="shop-photo">
        {shop.photo_key ? (
          <img 
            src={`/api/photo/${encodeURIComponent(shop.photo_key)}`} 
            alt={`Free sauce at ${shop.name}`} 
            class="photo"
          />
        ) : (
          <div class="photo-placeholder">
            🥫<br />
            <small>No photo yet</small>
          </div>
        )}
      </div>
      
      <div class="shop-info">
        <h1>
          {shop.name}
          {shop.verified && <span class="verified">✅</span>}
        </h1>
        
        <p class="address">📍 {shop.address}</p>
        
        <div class="sauce-types">
          {shop.sauce_types.split(',').map((sauce: string) => (
            <span class="sauce-chip">{sauce.trim()}</span>
          ))}
        </div>
        
        <div class="stats">
          <div class="votes">
            <span class="vote-count up">👍 {shop.vote_up_count} confirmed</span>
            <span class="vote-count down">👎 {shop.vote_down_count} denied</span>
          </div>
          <div class="last-updated">
            Updated {timeAgo(shop.last_activity)}
          </div>
        </div>
      </div>
    </div>

    <div class="vote-section">
      <h2>Does this shop offer free sauce?</h2>
      <p>Been here recently? Let everyone know if the sauce is still flowing.</p>
      
      <form id="voteForm" class="vote-form">
        <input type="hidden" name="shop_id" value={shop.id} />
        
        <div class="vote-buttons">
          <button type="button" class="vote-btn" data-vote="up">
            👍 <span>Yes — sauce is available</span>
          </button>
          <button type="button" class="vote-btn" data-vote="down">
            👎 <span>No — couldn't find sauce</span>
          </button>
        </div>
        
        <div class="extra-fields" style="display: none;">
          <div class="field">
            <label for="comment">Comment <span class="optional">(optional)</span></label>
            <textarea id="comment" name="comment" rows="2" placeholder="e.g. Tomato and BBQ on the counter, self-serve" maxlength="500"></textarea>
          </div>
          
          <div class="field">
            <label for="email">Email <span class="optional">(to verify you're a real person)</span></label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
            <small>We'll send a quick confirmation link. No spam, promise.</small>
          </div>
          
          <button type="submit" class="submit-vote">
            Send Confirmation
          </button>
        </div>
        
        <div id="voteMsg" class="vote-msg" style="display: none;"></div>
      </form>
    </div>

    {confirmations.length > 0 && (
      <div class="confirmations-section">
        <h2>Community Reports</h2>
        <ul class="confirmations-list">
          {confirmations.map((c: any) => (
            <li class={`confirmation ${c.vote}`}>
              <span class="confirmation-icon">{c.vote === 'up' ? '👍' : '👎'}</span>
              <div class="confirmation-body">
                {c.comment && <p class="confirmation-comment">{c.comment}</p>}
                <span class="confirmation-time">{timeAgo(c.confirmed_at)}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="back-link">
      <a href="/">← Back to the map</a>
    </div>
  </main>

  <style>
    .shop-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 1rem;
    }

    .voted-banner {
      background: #d5f5e3;
      color: #1e8449;
      padding: 1rem;
      border-radius: 0.5rem;
      text-align: center;
      margin-bottom: 1.5rem;
      font-weight: 600;
    }

    .shop-header {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .shop-photo {
      aspect-ratio: 1;
      border-radius: 0.75rem;
      overflow: hidden;
      background: #f8f9fa;
    }

    .photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .photo-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: #6c757d;
      text-align: center;
    }

    .photo-placeholder small {
      font-size: 0.8rem;
      margin-top: 0.5rem;
    }

    .shop-info h1 {
      font-size: 2rem;
      color: var(--sauce-red);
      margin: 0 0 1rem 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .verified {
      font-size: 1.5rem;
    }

    .address {
      font-size: 1.1rem;
      margin: 0 0 1rem 0;
      opacity: 0.8;
    }

    .sauce-types {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .sauce-chip {
      background: var(--sauce-red);
      color: white;
      padding: 0.25rem 0.75rem;
      border-radius: 1rem;
      font-size: 0.9rem;
      font-weight: 600;
    }

    .stats {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .votes {
      display: flex;
      gap: 1rem;
    }

    .vote-count {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 1.1rem;
      font-weight: 600;
    }

    .last-updated {
      font-size: 0.9rem;
      opacity: 0.7;
    }

    .vote-section {
      background: #f8f9fa;
      padding: 2rem;
      border-radius: 0.75rem;
      margin-bottom: 2rem;
    }

    .vote-section h2 {
      margin: 0 0 0.5rem 0;
      color: var(--sauce-red);
    }

    .vote-section p {
      margin: 0 0 1.5rem 0;
      opacity: 0.8;
    }

    .vote-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .vote-btn {
      padding: 1rem;
      border: 2px solid #e9ecef;
      border-radius: 0.5rem;
      background: white;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .vote-btn:hover {
      border-color: var(--sauce-red);
      transform: translateY(-2px);
    }

    .vote-btn.selected {
      border-color: var(--sauce-red);
      background: var(--sauce-red);
      color: white;
    }

    .extra-fields {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .field label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .optional {
      font-weight: 400;
      opacity: 0.6;
      font-size: 0.85rem;
    }

    .field input,
    .field textarea {
      width: 100%;
      padding: 0.75rem;
      border: 2px solid #e9ecef;
      border-radius: 0.5rem;
      font-size: 1rem;
      font-family: inherit;
      box-sizing: border-box;
    }

    .field input:focus,
    .field textarea:focus {
      outline: none;
      border-color: var(--sauce-red);
    }

    .field textarea {
      resize: vertical;
      min-height: 60px;
    }

    .field small {
      display: block;
      margin-top: 0.25rem;
      font-size: 0.8rem;
      opacity: 0.7;
    }

    .submit-vote {
      background: var(--sauce-red);
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }

    .submit-vote:hover {
      background: #c82333;
    }

    .vote-msg {
      margin-top: 1rem;
      padding: 0.75rem;
      border-radius: 0.5rem;
      font-weight: 600;
    }

    .vote-msg.success {
      background: #d5f5e3;
      color: #1e8449;
    }

    .vote-msg.error {
      background: #fadbd8;
      color: #922b21;
    }

    .confirmations-section {
      margin-bottom: 2rem;
    }

    .confirmations-section h2 {
      font-size: 1.3rem;
      color: var(--meat, #3d2c2c);
      margin: 0 0 1rem 0;
    }

    .confirmations-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .confirmation {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      background: #f8f9fa;
      border-radius: 0.5rem;
      border-left: 3px solid #e9ecef;
    }

    .confirmation.up {
      border-left-color: var(--aussie-green, #00843D);
    }

    .confirmation.down {
      border-left-color: var(--sauce-red, #dc3545);
    }

    .confirmation-icon {
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .confirmation-body {
      flex: 1;
      min-width: 0;
    }

    .confirmation-comment {
      margin: 0 0 0.25rem 0;
      font-size: 0.95rem;
      line-height: 1.4;
    }

    .confirmation-time {
      font-size: 0.8rem;
      opacity: 0.6;
    }

    .back-link {
      text-align: center;
    }

    .back-link a {
      color: var(--sauce-red);
      text-decoration: none;
      font-weight: 600;
    }

    .back-link a:hover {
      text-decoration: underline;
    }

    @media (max-width: 600px) {
      .shop-header {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .vote-buttons {
        grid-template-columns: 1fr;
      }

      .shop-info h1 {
        font-size: 1.5rem;
      }

      .stats {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }
    }
  </style>

  <script is:inline>
    let selectedVote = null;

    // Handle vote button selection
    document.querySelectorAll('.vote-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const vote = e.currentTarget.dataset.vote;
        
        // Remove previous selection
        document.querySelectorAll('.vote-btn').forEach(b => b.classList.remove('selected'));
        
        // Select current button
        e.currentTarget.classList.add('selected');
        selectedVote = vote;
        
        // Show extra fields
        document.querySelector('.extra-fields').style.display = 'flex';
      });
    });

    // Handle form submission
    document.getElementById('voteForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!selectedVote) return;
      
      const form = e.target;
      const btn = form.querySelector('.submit-vote');
      const msg = document.getElementById('voteMsg');
      
      btn.disabled = true;
      btn.textContent = 'Sending...';
      msg.style.display = 'none';
      
      const data = {
        shop_id: parseInt(form.querySelector('[name="shop_id"]').value),
        email: form.querySelector('#email').value.trim(),
        vote: selectedVote,
        comment: form.querySelector('#comment').value.trim() || null
      };
      
      try {
        const res = await fetch('/api/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        const result = await res.json();
        
        if (res.ok) {
          msg.className = 'vote-msg success';
          msg.textContent = '📧 Check your email to confirm!';
          msg.style.display = 'block';
          form.reset();
          selectedVote = null;
          document.querySelectorAll('.vote-btn').forEach(b => b.classList.remove('selected'));
          document.querySelector('.extra-fields').style.display = 'none';
        } else {
          throw new Error(result.error || 'Something went wrong');
        }
      } catch (err) {
        msg.className = 'vote-msg error';
        msg.textContent = `❌ ${err.message}`;
        msg.style.display = 'block';
      }
      
      btn.disabled = false;
      btn.textContent = 'Send Confirmation';
    });
  </script>
</Layout>